@model List<SmartExamSystem.Models.ExamMaster>

@{
    ViewData["Title"] = "Available Exams";
    var attemptedExams = ViewBag.AttemptedExams as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var questionCounts = ViewBag.ExamQuestionCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<style>
    .page-wrap { max-width: 1200px; margin: 0 auto; padding: 28px 20px; }
    .top-bar {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 28px; flex-wrap: wrap; gap: 12px;
    }
    .top-bar h1 { font-size: 1.6rem; font-weight: 800; color: var(--text-primary); display: flex; align-items: center; gap: 10px; }
    .nav-links { display: flex; gap: 10px; }
    .exams-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; }
    .exam-card {
        background: var(--bg-card); border: 1px solid var(--glass-border);
        border-radius: var(--radius-lg); padding: 24px;
        transition: all var(--transition-base);
        display: flex; flex-direction: column;
        position: relative; overflow: hidden;
    }
    .exam-card::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
        background: var(--gradient-primary);
    }
    .exam-card:hover { transform: translateY(-6px); box-shadow: 0 12px 32px rgba(0,0,0,0.3); border-color: var(--primary); }
    .exam-card-title { font-size: 1.1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 14px; }
    .exam-card-info { flex: 1; display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
    .exam-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px solid var(--border-light); font-size: 0.88rem; }
    .exam-row:last-child { border-bottom: none; }
    .exam-row-label { color: var(--text-muted); font-weight: 600; }
    .exam-row-value { color: var(--text-primary); font-weight: 600; }
    .desc-text { color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 14px; line-height: 1.5; }
    .attempted-tag {
        display: flex; align-items: center; gap: 8px;
        padding: 10px 14px; border-radius: var(--radius-md);
        font-size: 0.85rem; font-weight: 600;
    }
    .attempted-done { background: var(--success-bg); color: var(--success); }
    .attempted-term { background: var(--danger-bg); color: var(--danger); }
    .exam-status-badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 6px 12px; border-radius: var(--radius-md);
        font-size: 0.75rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.5px; margin-bottom: 10px;
    }
    .status-scheduled { background: var(--info-bg); color: var(--info); }
    .status-open { background: var(--success-bg); color: var(--success); }
    .status-closed { background: var(--danger-bg); color: var(--danger); }
    @@media (max-width: 768px) { .exams-grid { grid-template-columns: 1fr; } }
</style>

<div class="page-wrap animate-fade-in-up">
    <div class="top-bar">
        <h1><i class="fas fa-book-open" style="color:var(--primary);"></i> Available Exams</h1>
        <div class="nav-links">
            <a href="/Student/Dashboard" class="ses-btn ses-btn-ghost ses-btn-sm"><i class="fas fa-chart-bar"></i> Dashboard</a>
            <a href="/Student/Profile" class="ses-btn ses-btn-ghost ses-btn-sm"><i class="fas fa-user"></i> Profile</a>
            <a href="/Student/Logout" class="ses-btn ses-btn-danger ses-btn-sm"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </div>
    </div>

    <p style="color:var(--text-secondary);margin-bottom:24px;">Welcome, <strong style="color:var(--text-primary);">@ViewBag.StudentName</strong>! Here are the active exams.</p>

    @if (TempData["Error"] != null)
    {
        <div class="ses-alert ses-alert-warning" style="margin-bottom:20px;"><i class="fas fa-clock"></i> @TempData["Error"]</div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="ses-alert ses-alert-success" style="margin-bottom:20px;"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
    }

    @if (Model.Count == 0)
    {
        <div class="ses-card"><div class="ses-empty">
            <i class="fas fa-book"></i>
            <h3>No Exams Available</h3>
            <p>No active exams at the moment. Check back later.</p>
        </div></div>
    }
    else
    {
        <div class="exams-grid">
            @foreach (var exam in Model)
            {
                var studentAttempt = attemptedExams.FirstOrDefault(a => a.ExamId == exam.ExamId);
                bool hasAttempted = studentAttempt != null;
                int qCount = questionCounts.ContainsKey(exam.ExamId) ? questionCounts[exam.ExamId] : 0;

                <div class="exam-card">
                    <h3 class="exam-card-title">@exam.ExamName</h3>
                    @{
                        var now = System.DateTime.Now;
                        var startTime = exam.StartTime ?? System.DateTime.MinValue;
                        var endTime = exam.EndTime ?? System.DateTime.MaxValue;
                        var statusClass = "status-closed";
                        var statusText = "Closed";
                        var statusIcon = "fa-times-circle";

                        if (now < startTime)
                        {
                            statusClass = "status-scheduled";
                            statusText = "Scheduled";
                            statusIcon = "fa-calendar-check";
                        }
                        else if (now >= startTime && now <= endTime)
                        {
                            statusClass = "status-open";
                            statusText = "Open Now";
                            statusIcon = "fa-play-circle";
                        }
                    }
                    <div class="exam-status-badge @statusClass">
                        <i class="fas @statusIcon"></i> @statusText
                    </div>
                    @if (!string.IsNullOrEmpty(exam.Subject))
                    {
                        <div style="font-size:0.85rem;color:var(--primary);margin-top:-10px;margin-bottom:12px;font-weight:600;">@exam.Subject</div>
                    }

                    @if (!string.IsNullOrEmpty(exam.Description))
                    {
                        <p class="desc-text">@exam.Description</p>
                    }

                    <div class="exam-card-info">
                        <div class="exam-row">
                            <span class="exam-row-label"><i class="fas fa-clock"></i> Duration</span>
                            <span class="exam-row-value">@exam.DurationMinutes min</span>
                        </div>
                        <div class="exam-row">
                            <span class="exam-row-label"><i class="fas fa-star"></i> Total Marks</span>
                            <span class="exam-row-value">@exam.TotalMarks</span>
                        </div>
                        <div class="exam-row">
                            <span class="exam-row-label"><i class="fas fa-question-circle"></i> Questions</span>
                            <span class="exam-row-value">@qCount</span>
                        </div>
                        <div class="exam-row" style="flex-direction:column;align-items:flex-start;gap:4px;">
                            <span class="exam-row-label"><i class="fas fa-calendar-alt"></i> Available Time</span>
                            <span class="exam-row-value" style="font-size:0.8rem;">
                                @(exam.StartTime?.ToString("dd MMM yy, hh:mm tt") ?? "Anytime") - <br/>
                                @(exam.EndTime?.ToString("dd MMM yy, hh:mm tt") ?? "Anytime")
                            </span>
                        </div>
                    </div>

                    @if (hasAttempted)
                    {
                        string attemptStatus = studentAttempt.Status;
                        if (attemptStatus == "Started")
                        {
                            <a href="/Exam/ExamPage/@(studentAttempt.AttemptId)" class="ses-btn ses-btn-accent" style="width:100%;">
                                <i class="fas fa-play-circle"></i> Resume Exam
                            </a>
                        }
                        else
                        {
                            <div class="attempted-tag @(attemptStatus == "Terminated" ? "attempted-term" : "attempted-done")">
                                <i class="fas fa-@(attemptStatus == "Terminated" ? "ban" : "check-circle")"></i>
                                @(attemptStatus == "Terminated" ? "Terminated" : "Completed") — Score: @studentAttempt.Score
                            </div>
                            <a href="/Exam/Result/@(studentAttempt.AttemptId)" class="ses-btn ses-btn-ghost ses-btn-sm" style="margin-top:8px;">
                                <i class="fas fa-eye"></i> View Result
                            </a>
                        }
                    }
                    else
                    {
                        <a href="/Exam/Start/@exam.ExamId" class="ses-btn ses-btn-primary" style="width:100%;text-align:center;"
                           onclick="return confirm('Start exam: @exam.ExamName?\n\nDuration: @exam.DurationMinutes minutes\nTotal Marks: @exam.TotalMarks\n\nOnce started, the timer cannot be paused.');">
                            <i class="fas fa-rocket"></i> Start Exam
                        </a>
                    }
                </div>
            }
        </div>
    }
</div>
