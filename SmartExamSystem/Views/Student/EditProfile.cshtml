@model SmartExamSystem.Models.ExamStudent
@{ ViewData["Title"] = "Edit Profile"; }

<div style="max-width:600px;margin:0 auto;padding:28px 20px;" class="animate-fade-in-up">
    <a href="/Student/Profile" class="ses-back-link"><i class="fas fa-arrow-left"></i> Back to Profile</a>

    @if (TempData["Success"] != null)
    {
        <div class="ses-alert ses-alert-success"><i class="fas fa-check-circle"></i> @TempData["Success"]</div>
    }

    <div class="ses-card" style="padding:36px;">
        <h1 style="font-size:1.5rem;font-weight:800;color:var(--text-primary);text-align:center;margin-bottom:32px;">
            <i class="fas fa-user-edit" style="color:var(--primary);"></i> Edit Profile
        </h1>

        <form method="post" asp-action="EditProfile">
            <div class="ses-form-group">
                <label class="ses-label">Full Name *</label>
                <input type="text" name="StudentName" class="ses-input" value="@Model.StudentName" required />
            </div>
            <div class="ses-form-group">
                <label class="ses-label">Email Address</label>
                <input type="email" name="Email" class="ses-input" value="@Model.Email" readonly
                       style="opacity:0.6;cursor:not-allowed;" />
                <small style="color:var(--text-muted);font-size:0.78rem;">Email cannot be changed</small>
            </div>
            <div class="ses-form-group">
                <label class="ses-label">Phone Number</label>
                <input type="tel" name="PhoneNumber" class="ses-input" value="@(Model.PhoneNumber ?? "")" placeholder="+91-XXXXXXXXXX" />
            </div>
            <div class="ses-form-group">
                <label class="ses-label">Address</label>
                <textarea name="Address" class="ses-input" placeholder="Enter your address">@(Model.Address ?? "")</textarea>
            </div>
            <div class="ses-form-actions">
                <button type="submit" class="ses-btn ses-btn-primary" style="flex:1;"><i class="fas fa-check"></i> Save Changes</button>
                <a href="/Student/Profile" class="ses-btn ses-btn-ghost" style="flex:1;"><i class="fas fa-times"></i> Cancel</a>
            </div>
        </form>
    </div>
</div>
