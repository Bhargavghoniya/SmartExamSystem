@model SmartExamSystem.Models.ExamMaster
@{ ViewData["Title"] = "Create Exam"; }

<div style="max-width:700px;margin:0 auto;padding:28px 20px;" class="animate-fade-in-up">
    <a href="/Admin/ExamList" class="ses-back-link"><i class="fas fa-arrow-left"></i> Back to Exams</a>
    <div class="ses-card" style="padding:36px;">
        <h1 style="font-size:1.5rem;font-weight:800;color:var(--text-primary);text-align:center;margin-bottom:8px;">
            <i class="fas fa-book-open" style="color:var(--primary);"></i> Create New Exam
        </h1>
        <p style="text-align:center;color:var(--text-muted);margin-bottom:32px;font-size:0.9rem;">Fill in the exam details below</p>
        <form method="post" asp-action="AddExam">
            <div class="ses-form-group">
                <label class="ses-label">Exam Name *</label>
                <input type="text" name="ExamName" class="ses-input" placeholder="e.g., Mathematics Final Exam" required />
                <span asp-validation-for="ExamName" class="ses-validation-error"></span>
            </div>
            <div class="ses-form-group">
                <label class="ses-label">Subject *</label>
                <input type="text" name="Subject" class="ses-input" placeholder="e.g., ASP.NET WebForms, Java" required />
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
                <div class="ses-form-group">
                    <label class="ses-label">Start Time *</label>
                    <input type="datetime-local" name="StartTime" class="ses-input" required />
                </div>
                <div class="ses-form-group">
                    <label class="ses-label">End Time *</label>
                    <input type="datetime-local" name="EndTime" class="ses-input" required />
                </div>
            </div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
                <div class="ses-form-group">
                    <label class="ses-label">Duration (minutes) *</label>
                    <input type="number" name="DurationMinutes" class="ses-input" placeholder="60" min="5" required />
                    <small style="color:var(--text-muted);font-size:0.78rem;">Minimum 5 minutes</small>
                </div>
                <div class="ses-form-group">
                    <label class="ses-label">Total Marks *</label>
                    <input type="number" name="TotalMarks" class="ses-input" placeholder="100" min="1" required />
                </div>
            </div>
            <div class="ses-form-group">
                <label class="ses-label">Description</label>
                <textarea name="Description" class="ses-input" placeholder="Enter exam description (optional)"></textarea>
            </div>
            <div class="ses-form-group">
                <label class="ses-label">Instructions</label>
                <textarea name="Instructions" class="ses-input" placeholder="Enter instructions for students (optional)"></textarea>
            </div>
            <div class="ses-form-actions">
                <button type="submit" class="ses-btn ses-btn-primary" style="flex:1;"><i class="fas fa-check"></i> Create Exam</button>
                <a href="/Admin/ExamList" class="ses-btn ses-btn-ghost" style="flex:1;"><i class="fas fa-times"></i> Cancel</a>
            </div>
        </form>
    </div>
</div>
